# Gateway Environment Configuration

# Environment mode: development | production
# В development: Secure cookies = false (для HTTP)
# В production: Secure cookies = true (только HTTPS)
ENVIRONMENT=development

# CORS Configuration
# Development: можно использовать "*"
# Production: ОБЯЗАТЕЛЬНО указать конкретные домены!
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Server Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_RPS=100

# NATS Configuration
NATS_URL=nats://localhost:4222

# Logging
LOG_LEVEL=info
